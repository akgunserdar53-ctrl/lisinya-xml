name: Kuzgun Price Engine v1.0

on:
  workflow_dispatch:
    inputs:
      barcode:
        description: "Fiyati incelenecek tek barkod"
        required: true
        default: "9786051008608"
        type: string
      mode:
        description: "KONTROL gondermez; UYGULA tek urunun fiyatini gonderir"
        required: true
        default: "KONTROL"
        type: choice
        options:
          - KONTROL
          - UYGULA
      confirmation:
        description: "Normal uygulama: FIYATI_GUNCELLE | Fark %40'tan buyukse: RISKLI_FIYATI_ONAYLA"
        required: false
        default: ""
        type: string

permissions:
  contents: read

concurrency:
  group: kuzgun-price-engine-single-product
  cancel-in-progress: false

jobs:
  single-product-price-control:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    env:
      XML_URL: https://akgunserdar53-ctrl.github.io/lisinya-xml/lisinyakitap-guncel.xml
      TEST_BARCODE: ${{ inputs.barcode }}
      RUN_MODE: ${{ inputs.mode }}
      CONFIRMATION: ${{ inputs.confirmation }}
      TRENDYOL_SELLER_ID: ${{ secrets.TRENDYOL_SELLER_ID }}
      TRENDYOL_API_KEY: ${{ secrets.TRENDYOL_API_KEY }}
      TRENDYOL_API_SECRET: ${{ secrets.TRENDYOL_API_SECRET }}
      TRENDYOL_STOREFRONT_CODE: TR

    steps:
      - name: Kuzgun fiyat motorunu calistir
        shell: bash
        run: |
          set -euo pipefail
          python3 - <<'PY'
          import base64
          import json
          import os
          import time
          import urllib.error
          import urllib.parse
          import urllib.request
          import xml.etree.ElementTree as ET
          from decimal import Decimal, InvalidOperation, ROUND_FLOOR, ROUND_HALF_UP

          XML_URL = os.environ["XML_URL"]
          BARCODE = os.environ["TEST_BARCODE"].strip()
          MODE = os.environ["RUN_MODE"].strip().upper()
          CONFIRMATION = os.environ.get("CONFIRMATION", "").strip()

          SELLER_ID = os.environ.get("TRENDYOL_SELLER_ID", "").strip()
          API_KEY = os.environ.get("TRENDYOL_API_KEY", "").strip()
          API_SECRET = os.environ.get("TRENDYOL_API_SECRET", "").strip()
          STOREFRONT = os.environ.get("TRENDYOL_STOREFRONT_CODE", "TR").strip()

          BASE = "https://apigw.trendyol.com"
          REPORT_PATH = "kuzgun-fiyat-kontrol-raporu.json"

          VAT_PERCENT = Decimal("0")
          COMMISSION_PERCENT = Decimal("20")
          PAYMENT_COST_PERCENT = Decimal("4")
          BASKET_DISCOUNT_PERCENT = Decimal("10")
          SHIPPING_RESERVE = Decimal("110")
          MINIMUM_PROFIT = Decimal("20")
          MAX_CHANGE_PERCENT = Decimal("40")

          ONE = Decimal("1")
          HUNDRED = Decimal("100")

          report = {
              "engine": "Kuzgun Price Engine v1.0",
              "mode": MODE,
              "barcode": BARCODE,
              "xmlUrl": XML_URL,
              "sent": False,
          }

          def save_report():
              with open(REPORT_PATH, "w", encoding="utf-8") as handle:
                  json.dump(report, handle, ensure_ascii=False, indent=2)

          def local_name(tag):
              return tag.rsplit("}", 1)[-1].lower()

          def child_text(product, wanted):
              for child in product:
                  if local_name(child.tag) == wanted:
                      return (child.text or "").strip()
              return ""

          def money(value, field):
              raw = str(value).strip().replace(" ", "").replace(",", ".")
              try:
                  number = Decimal(raw)
              except InvalidOperation:
                  raise SystemExit(f"Gecersiz {field}: {value!r}")
              if number <= 0:
                  raise SystemExit(f"{field} sifir veya negatif olamaz: {number}")
              return number

          def decimal_text(value, places="0.01"):
              return str(value.quantize(Decimal(places), rounding=ROUND_HALF_UP))

          def round_up_to_90(value):
              whole = value.to_integral_value(rounding=ROUND_FLOOR)
              candidate = whole + Decimal("0.90")
              if candidate < value:
                  candidate += Decimal("1.00")
              return candidate.quantize(Decimal("0.00"))

          def profit_rate_for(base_cost):
              if base_cost <= Decimal("50"):
                  return Decimal("30")
              if base_cost <= Decimal("100"):
                  return Decimal("25")
              if base_cost <= Decimal("200"):
                  return Decimal("20")
              if base_cost <= Decimal("500"):
                  return Decimal("17")
              return Decimal("15")

          def request_json(method, url, payload=None):
              credentials = base64.b64encode(
                  f"{API_KEY}:{API_SECRET}".encode("utf-8")
              ).decode("ascii")
              headers = {
                  "Authorization": f"Basic {credentials}",
                  "User-Agent": f"{SELLER_ID} - SelfIntegration",
                  "storeFrontCode": STOREFRONT,
                  "Accept": "application/json",
              }
              data = None
              if payload is not None:
                  headers["Content-Type"] = "application/json"
                  data = json.dumps(payload).encode("utf-8")

              request = urllib.request.Request(
                  url,
                  data=data,
                  headers=headers,
                  method=method,
              )

              try:
                  with urllib.request.urlopen(request, timeout=60) as response:
                      body = response.read().decode("utf-8")
                      return json.loads(body) if body else {}
              except urllib.error.HTTPError as error:
                  body = error.read().decode("utf-8", errors="replace")
                  raise RuntimeError(
                      f"Trendyol HTTP {error.code}: {body[:2000]}"
                  ) from None

          if not BARCODE:
              raise SystemExit("Barkod bos olamaz.")
          if MODE not in {"KONTROL", "UYGULA"}:
              raise SystemExit("Gecersiz mod.")
          if not all((SELLER_ID, API_KEY, API_SECRET)):
              raise SystemExit("GitHub Secrets eksik.")

          print("Temiz XML indiriliyor...")
          with urllib.request.urlopen(XML_URL, timeout=120) as response:
              tree = ET.parse(response)

          matches = []
          for product in tree.getroot().iter():
              if local_name(product.tag) != "product":
                  continue
              if child_text(product, "barkod") == BARCODE:
                  matches.append(product)

          if len(matches) != 1:
              report["xmlMatchCount"] = len(matches)
              save_report()
              raise SystemExit(
                  f"Guvenlik durdurmasi: XML'de barkod {len(matches)} kez bulundu."
              )

          product = matches[0]
          raw_xml_price = child_text(product, "price")
          xml_price = money(raw_xml_price, "XML price")

          payment_cost = xml_price * PAYMENT_COST_PERCENT / HUNDRED
          base_cost = xml_price + payment_cost + SHIPPING_RESERVE

          profit_rate_percent = profit_rate_for(base_cost)
          percentage_profit = base_cost * profit_rate_percent / HUNDRED
          profit_amount = max(percentage_profit, MINIMUM_PROFIT)
          required_net = base_cost + profit_amount

          commission_factor = ONE - COMMISSION_PERCENT / HUNDRED
          basket_factor = ONE - BASKET_DISCOUNT_PERCENT / HUNDRED

          raw_target_price = required_net / commission_factor / basket_factor
          target_price = round_up_to_90(raw_target_price)
          basket_price = (
              target_price * basket_factor
          ).quantize(Decimal("0.01"), rounding=ROUND_HALF_UP)

          estimated_commission = (
              basket_price * COMMISSION_PERCENT / HUNDRED
          ).quantize(Decimal("0.01"), rounding=ROUND_HALF_UP)
          estimated_net_after_commission = (
              basket_price - estimated_commission
          ).quantize(Decimal("0.01"), rounding=ROUND_HALF_UP)
          estimated_profit = (
              estimated_net_after_commission - base_cost
          ).quantize(Decimal("0.01"), rounding=ROUND_HALF_UP)

          if target_price <= 0 or target_price > Decimal("1000000"):
              raise SystemExit(
                  f"Guvenlik durdurmasi: hesaplanan fiyat {target_price}"
              )

          target_multiplier = target_price / xml_price
          if target_multiplier > Decimal("10"):
              raise SystemExit(
                  "Guvenlik durdurmasi: hesaplanan fiyat carpani "
                  f"cok yuksek: {target_multiplier}"
              )

          report.update({
              "xmlMatchCount": 1,
              "xmlProductName": child_text(product, "name"),
              "xmlModel": child_text(product, "model"),
              "xmlQuantity": child_text(product, "quantity"),
              "xmlPrice": decimal_text(xml_price),
              "vatPercent": decimal_text(VAT_PERCENT),
              "paymentCostPercent": decimal_text(PAYMENT_COST_PERCENT),
              "paymentCostAmount": decimal_text(payment_cost),
              "shippingReserve": decimal_text(SHIPPING_RESERVE),
              "baseCost": decimal_text(base_cost),
              "profitRatePercent": decimal_text(profit_rate_percent),
              "minimumProfit": decimal_text(MINIMUM_PROFIT),
              "calculatedProfitAmount": decimal_text(profit_amount),
              "requiredNet": decimal_text(required_net),
              "commissionPercent": decimal_text(COMMISSION_PERCENT),
              "basketDiscountPercent": decimal_text(BASKET_DISCOUNT_PERCENT),
              "rawCalculatedListPrice": decimal_text(raw_target_price),
              "calculatedListPrice": decimal_text(target_price),
              "calculatedBasketPrice": decimal_text(basket_price),
              "estimatedCommissionAmount": decimal_text(estimated_commission),
              "estimatedNetAfterCommission": decimal_text(
                  estimated_net_after_commission
              ),
              "estimatedProfitAfterRounding": decimal_text(estimated_profit),
          })

          query = urllib.parse.urlencode({"barcode": BARCODE})
          product_url = (
              f"{BASE}/integration/product/sellers/{SELLER_ID}"
              f"/products/approved/inventory-and-price?{query}"
          )

          trendyol_response = request_json("GET", product_url)
          content = trendyol_response.get("content") or []

          exact = []
          for trendyol_product in content:
              for variant in trendyol_product.get("variants", []):
                  if str(variant.get("barcode", "")).strip() == BARCODE:
                      exact.append({
                          "variant": variant,
                          "title": trendyol_product.get("title"),
                      })

          if len(exact) != 1:
              report["trendyolMatchCount"] = len(exact)
              report["trendyolResponse"] = trendyol_response
              save_report()
              raise SystemExit(
                  "Guvenlik durdurmasi: Trendyol'da barkod "
                  f"{len(exact)} kez bulundu."
              )

          match = exact[0]
          item = match["variant"]

          sale_price = money(
              item.get("salePrice"),
              "Trendyol salePrice",
          )
          list_price = money(
              item.get("listPrice"),
              "Trendyol listPrice",
          )

          absolute_difference = abs(target_price - sale_price)
          change_percent = (
              absolute_difference / sale_price * HUNDRED
          ).quantize(Decimal("0.01"), rounding=ROUND_HALF_UP)
          risky_change = change_percent > MAX_CHANGE_PERCENT

          report.update({
              "trendyolMatchCount": 1,
              "trendyolTitle": match.get("title"),
              "trendyolSalePrice": decimal_text(sale_price),
              "trendyolListPrice": decimal_text(list_price),
              "trendyolQuantity": item.get("quantity"),
              "absolutePriceDifference": decimal_text(absolute_difference),
              "changePercentAgainstCurrentSalePrice": decimal_text(
                  change_percent
              ),
              "maximumAutomaticChangePercent": decimal_text(
                  MAX_CHANGE_PERCENT
              ),
              "riskyChange": risky_change,
              "requiredConfirmation": (
                  "RISKLI_FIYATI_ONAYLA"
                  if risky_change
                  else "FIYATI_GUNCELLE"
              ),
              "sent": False,
          })

          save_report()

          print("=" * 68)
          print(f"URUN: {BARCODE} | {report['xmlProductName']}")
          print(f"XML ALIS FIYATI: {decimal_text(xml_price)} TL")
          print(
              "ODEME MALIYETI: "
              f"%{decimal_text(PAYMENT_COST_PERCENT)} = "
              f"{decimal_text(payment_cost)} TL"
          )
          print(f"KARGO REZERVI: {decimal_text(SHIPPING_RESERVE)} TL")
          print(f"TABAN MALIYET: {decimal_text(base_cost)} TL")
          print(
              "KAR: "
              f"%{decimal_text(profit_rate_percent)} = "
              f"{decimal_text(profit_amount)} TL"
          )
          print(f"GEREKLI NET: {decimal_text(required_net)} TL")
          print(
              "HESAPLANAN LISTE FIYATI: "
              f"{decimal_text(target_price)} TL"
          )
          print(
              "TAHMINI SEPET FIYATI: "
              f"{decimal_text(basket_price)} TL"
          )
          print(
              "TAHMINI NET KAR: "
              f"{decimal_text(estimated_profit)} TL"
          )
          print(
              "MEVCUT TRENDYOL SATIS FIYATI: "
              f"{decimal_text(sale_price)} TL"
          )
          print(
              "MEVCUT TRENDYOL LISTE FIYATI: "
              f"{decimal_text(list_price)} TL"
          )
          print(
              "FIYAT DEGISIM ORANI: "
              f"%{decimal_text(change_percent)}"
          )
          print("=" * 68)

          if MODE == "KONTROL":
              if risky_change:
                  print(
                      "UYARI: Fiyat farki %40 sinirini asti. "
                      "UYGULA modunda RISKLI_FIYATI_ONAYLA gerekir."
                  )
              print(
                  "KONTROL modu: Trendyol'a hicbir fiyat veya stok "
                  "gonderilmedi."
              )
              save_report()
              raise SystemExit(0)

          required_confirmation = (
              "RISKLI_FIYATI_ONAYLA"
              if risky_change
              else "FIYATI_GUNCELLE"
          )

          if CONFIRMATION != required_confirmation:
              raise SystemExit(
                  "UYGULA icin confirmation alanina aynen "
                  f"{required_confirmation} yazilmali."
              )

          payload = {
              "items": [{
                  "barcode": BARCODE,
                  "salePrice": float(target_price),
                  "listPrice": float(target_price),
              }]
          }

          update_url = (
              f"{BASE}/integration/inventory/sellers/{SELLER_ID}"
              "/products/price-and-inventory"
          )
          submitted = request_json("POST", update_url, payload)
          batch_id = submitted.get("batchRequestId")

          if not batch_id:
              report["submitResponse"] = submitted
              save_report()
              raise SystemExit("Trendyol batchRequestId dondurmedi.")

          report.update({
              "sent": True,
              "batchRequestId": batch_id,
          })
          save_report()
          print(f"Trendyol kabul etti. batchRequestId={batch_id}")

          batch_url = (
              f"{BASE}/integration/product/sellers/{SELLER_ID}"
              f"/products/batch-requests/{urllib.parse.quote(batch_id)}"
          )

          result = {}
          for attempt in range(1, 31):
              result = request_json("GET", batch_url)
              status = str(result.get("status", "")).upper()
              print(
                  f"Sonuc sorgusu {attempt}/30: "
                  f"{status or 'BEKLIYOR'}"
              )
              if status in {"COMPLETED", "FAILED"}:
                  break
              time.sleep(5)
          else:
              report["batchResult"] = result
              save_report()
              raise SystemExit(
                  "Batch 150 saniyede tamamlanmadi."
              )

          report["batchResult"] = result
          save_report()

          items = result.get("items") or []
          failed_items = [
              batch_item
              for batch_item in items
              if str(batch_item.get("status", "")).upper() != "SUCCESS"
          ]

          if str(result.get("status", "")).upper() != "COMPLETED":
              raise SystemExit(
                  f"Batch basarisiz: {result.get('status')}"
              )

          if int(result.get("failedItemCount") or 0) or failed_items:
              reasons = [
                  batch_item.get("failureReasons")
                  for batch_item in failed_items
              ]
              raise SystemExit(
                  f"Fiyat guncellenemedi: {reasons}"
              )

          print(
              "BASARILI: Trendyol "
              f"{BARCODE} barkodunun fiyatini "
              f"{decimal_text(target_price)} TL olarak tamamladi."
          )
          PY

      - name: Kuzgun fiyat raporunu sakla
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: kuzgun-fiyat-raporu-${{ inputs.barcode }}
          path: kuzgun-fiyat-kontrol-raporu.json
          if-no-files-found: warn
          retention-days: 30
